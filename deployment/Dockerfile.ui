FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN useradd -m -u 1000 appuser && \
    chown -R appuser:appuser /app

# Copy requirements first for better layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY --chown=appuser:appuser src/ ./src/
COPY --chown=appuser:appuser scripts/run_ui.py .

# Copy environment template (will be overridden by docker-compose)
COPY --chown=appuser:appuser .env.example .env

# Create .streamlit directory for config
RUN mkdir -p /app/.streamlit && \
    chown -R appuser:appuser /app/.streamlit

# Switch to non-root user
USER appuser

# Expose port (default 8501, can be overridden by PORT env var)
EXPOSE ${PORT:-8501}

# Health check (uses PORT env var if set, defaults to 8501)
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:${PORT:-8501}/_stcore/health || exit 1

# Run Streamlit with production settings
CMD streamlit run src/ui/app.py --server.port=${PORT:-8501} --server.address=0.0.0.0 --server.headless=true --browser.gatherUsageStats=false


