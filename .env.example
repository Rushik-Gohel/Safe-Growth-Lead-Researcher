API_PORT=8000
UI_PORT=8501

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith (Optional - for tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=safe-growth-researcher

# Rate Limits (Gemini 1.5 Flash Tier 1)
GEMINI_RPM=15
GEMINI_TPM=1000000
GEMINI_TPD=1500

# Tavily Rate Limits
TAVILY_MONTHLY_LIMIT=1000

# Application Settings
LOG_LEVEL=INFO
ENABLE_METRICS=true
ENABLE_TRACING=true

# Security
MAX_INPUT_LENGTH=1000
ENABLE_GUARDRAILS=true

# Performance & Caching
ENABLE_CACHING=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Cache TTL overrides (in seconds)
WORKFLOW_CACHE_TTL=3600        # Workflow result cache (1 hour)
LINKEDIN_CACHE_TTL=3600        # LinkedIn profile cache (1 hour)
SEARCH_CACHE_TTL=1800          # Search results cache (30 minutes)
COMPANY_NEWS_CACHE_TTL=3600    # Company news cache (1 hour)
INDUSTRY_TRENDS_CACHE_TTL=7200 # Industry trends cache (2 hours)

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=2